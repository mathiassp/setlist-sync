# setlist-sync configuration
# Run "setlist-sync init" to set these up interactively.

# DJ Software: djay or rekordbox
DJ_SOFTWARE=

# djay Pro database path
# Default (macOS): ~/Music/djay/djay Media Library.djayMediaLibrary/MediaLibrary.db
DJAY_DB_PATH=

# Rekordbox database path (auto-discovered if empty)
# Default (macOS): ~/Library/Pioneer/rekordbox/master.db
# Default (Windows): %APPDATA%/Pioneer/rekordbox/master.db
REKORDBOX_DB_PATH=

# Rekordbox XML path (if set, uses XML instead of database)
REKORDBOX_XML_PATH=

# Match threshold (0-100, default: 85)
MATCH_THRESHOLD=85

# Handle duplicates interactively when multiple matches are found (true/false, default: false)
HANDLE_DUPLICATES=false

# Output directory for --files mode (default: output)
OUTPUT_DIR=output

# Music directory for --files mode (default: ~/Music)
MUSIC_DIR=~/Music
